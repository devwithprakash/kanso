# Database
# Example: postgres://postgres:postgres@localhost:5432/dev
DATABASE_URL=postgres://postgres:postgres@localhost:5433/dev

# Clerk (frontend)
# Use your Clerk publishable key or front-end API. Example values are placeholders.
